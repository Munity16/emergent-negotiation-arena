# Copy to .env or export in your shell. NEVER commit real values.

# Fireworks AI — enables the live LLM agent backend
FIREWORKS_API_KEY=
# Optional model override (default: accounts/fireworks/models/gpt-oss-120b)
FIREWORKS_MODEL=

# Optional runtime configuration
# AGENT_BACKEND=auto        # auto | fireworks | heuristic | replay
# SEMANTICS_MODE=visible    # visible (demo) | hidden (research)
# REPLAY_FILE=outputs/sample_run.json
# OUTPUT_DIR=outputs
# PORT=7860
